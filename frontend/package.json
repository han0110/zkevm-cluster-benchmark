{
  "name": "zkvm-benchmark-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/zkevm-cluster-benchmark/",
